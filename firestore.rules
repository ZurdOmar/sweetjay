rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Función para validar si el usuario es un administrador autorizado
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == 'morentinomar@gmail.com' || 
              request.auth.token.email == 'jeranmp8@gmail.com' ||
              request.auth.token.email == 'test@sweetjay.com');
    }

    // Colección de mensajes: 
    // - Cualquiera puede enviar un mensaje (crear)
    // - Cualquiera puede leerlos (para el muro de mensajes)
    // - SOLO los administradores pueden eliminarlos
    match /messages/{document=**} {
      allow create, read: if true;
      allow update, delete: if isAdmin();
    }

    // Todas las demás colecciones son de lectura pública
    // Pero solo los administradores pueden escribir
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reglas específicas por claridad
    match /images/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /videos/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /events/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /music/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /ads/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /promotions/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /carousel/{document=**} { allow read: if true; allow write: if isAdmin(); }
  }
}
